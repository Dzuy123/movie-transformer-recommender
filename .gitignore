__pycache__/
*.py[cod]
*.so
*.pyd
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# -------------------------
# Virtual environments
# -------------------------
.venv/
venv/
env/
FilmVenv/

